{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [],
    "ask": [
      "Bash(*ix-agent-run-cli*run*--agent*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/bash-build-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/path-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/search-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/sync-trigger.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/version-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
