# macOS
.DS_Store


# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# 各 artifact 的运行时产物
artifacts/*/output/
artifacts/ix-agent-run-cli/runs/
ix-agents/*/runs/

# 环境变量与密钥
.env
*.env.local

# 工作区状态文件
.indexed-baseline-version    # 基线版本水位线（tracked，update 时更新）
.indexed-migrations.log      # 迁移历史日志（tracked，append-only）

# 检查更新缓存（用户本地，不入版本库）
.indexed-update-check.json
