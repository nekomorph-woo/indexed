{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "indexed",
  "version": "0.1.0",
  "identifier": "com.indexed.gui",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && python3 ../../artifacts/ix-bundle-cli/main.py app-bundle --output ../src-tauri/baseline/"
  },
  "app": {
    "windows": [
      {
        "title": "indexed",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "baseline/": "baseline/"
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
